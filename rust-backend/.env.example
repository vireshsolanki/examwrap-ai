# ExamWrap Backend Environment Variables

# Google Gemini API
GOOGLE_API_KEY=keys
#GOOGLE_API_KEY=keys
GOOGLE_MODEL_NAME=gemini-2.5-flash
FRONTEND_URL=http://localhost:3000
BIND_ADDRESS=0.0.0.0:8080

# Server Configuration
SERVER_PORT=8080
RUST_LOG=info

# CORS (comma-separated origins for production)
ALLOWED_ORIGINS=*
