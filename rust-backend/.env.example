# ExamWrap Backend Environment Variables

# Google Gemini API - Primary Key (required)
GOOGLE_API_KEY=your_primary_api_key_here

# Google Gemini API - Fallback Key (optional, auto-switches when primary hits rate limit)
GOOGLE_API_KEY_2=your_fallback_api_key_here

GOOGLE_MODEL_NAME=gemini-2.5-flash
FRONTEND_URL=http://localhost:3000
BIND_ADDRESS=0.0.0.0:8080

# Server Configuration
SERVER_PORT=8080
RUST_LOG=info

# CORS (comma-separated origins for production)
ALLOWED_ORIGINS=*
